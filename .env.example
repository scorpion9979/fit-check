# Vercel AI Gateway auth — set ONE of these.
# 1) Static key (works anywhere, incl. local dev / CI):
AI_GATEWAY_API_KEY=

# 2) Or run `vercel env pull .env.local` on a linked project to get a
#    short-lived VERCEL_OIDC_TOKEN instead (no key needed).

# Optional: override the model routed through the gateway (provider/model slug).
# Defaults to anthropic/claude-haiku-4.5 (fast + cheap for structured extraction).
# FIT_CHECK_MODEL=anthropic/claude-sonnet-4.6
